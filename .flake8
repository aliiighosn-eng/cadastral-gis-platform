[flake8]
max-line-length = 88
extend-ignore =
    WPS110,
    WPS111,
    WPS115,
    WPS201,
    WPS202,
    WPS204,
    WPS210,
    WPS211,
    WPS214,
    WPS217,
    WPS220,
    WPS221,
    WPS223,
    WPS226,
    WPS229,
    WPS230,
    WPS231,
    WPS232,
    WPS235,
    WPS237,
    WPS327,
    WPS335,
    WPS358,
    WPS404,
    WPS420,
    WPS421,
    WPS432,
    WPS459,
    WPS476,
    WPS501,
    WPS504,
    WPS505,
    WPS515,
    WPS529,
    WPS602,
    E203
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    .eggs,
    *.egg-info
